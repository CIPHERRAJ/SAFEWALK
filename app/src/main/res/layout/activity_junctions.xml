<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Junctions Directory"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/primary"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/btnAnnaSilai"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Anna Silai"
        android:textAllCaps="false"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnGandhipuram"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Gandhipuram"
        android:textAllCaps="false"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnSinganallur"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Singanallur"
        android:textAllCaps="false"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnLakshmiMills"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Lakshmi Mills"
        android:textAllCaps="false"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnUkkadam"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ukkadam"
        android:textAllCaps="false"
        android:layout_marginBottom="12dp" />

</LinearLayout>
